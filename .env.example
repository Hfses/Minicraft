# ---- Backend (server/) ----
# Single port serves REST + WebSocket signaling (/ws) + WebSocket relay (/relay).
PORT=8080
# Seconds of inactivity before a room/session is garbage-collected.
SESSION_TTL_SECONDS=180

# ---- App (app/) ----
# Base URL of the backend the mobile app talks to.
# Production build points at the deployed backend, e.g. https://crafttogether-hfses.fly.dev
# For local dev with a physical phone, use your computer's LAN IP, e.g. http://192.168.0.10:8080
EXPO_PUBLIC_API_URL=http://127.0.0.1:8080
